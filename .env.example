# =============================================================================
# First Aid Box Inspection System - environment template
#
# Copy to .env.local for local development. Configure the same keys in
# Vercel Project Settings > Environment Variables for deployment.
#
# Anything marked [SERVER ONLY] must NEVER be given a NEXT_PUBLIC_ prefix and
# must never appear in client-side code. NEXT_PUBLIC_* values are compiled
# into the browser bundle and are considered public.
# =============================================================================

# --- Supabase ----------------------------------------------------------------
# Dashboard > Project Settings > API.
# The anon/publishable key is safe to ship to the browser ONLY because Row
# Level Security is enabled on every table (see supabase/rls_policies.sql).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# [SERVER ONLY] Service role / secret key. Bypasses RLS entirely.
# Used exclusively inside server code (API routes) for:
#   - reading profile/box context to authorize a request
#   - writing inspections, inspection_items, auto top-up requests, box state
#   - the public usage-log submission endpoint (after validation + rate limit)
#   - the reminder cron job
#   - admin user / item-photo management endpoints
SUPABASE_SERVICE_ROLE_KEY=

# --- Cloudinary [SERVER ONLY] -------------------------------------------------
# Dashboard > Settings > API Keys.
# Uploads are SIGNED by an authenticated server route; the browser receives a
# short-lived signature, never the API secret. The cloud name is the only
# Cloudinary value that may appear client-side.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Upload folders are fixed in code (lib/cloudinary.ts):
#   first-aid/inspection-photos     - live box photos (first_aider/admin)
#   first-aid/item-reference-photos - checklist reference photos (admin only)

# --- Email [SERVER ONLY] (reminder cron) --------------------------------------
# Free no-owned-domain path: use Brevo. Create a free Brevo account, verify a
# sender email, then create an SMTP/API key. If BREVO_API_KEY is present, the
# app uses Brevo automatically. Resend remains supported as a fallback, but it
# normally requires a verified owned domain.
BREVO_API_KEY=

RESEND_API_KEY=
# Must be a verified sender in your chosen email provider. For Brevo, this can
# be your verified sender email, e.g. "First Aid Reminders <yourname@gmail.com>".
REMINDER_FROM_EMAIL="First Aid Reminders <your-verified-sender@example.com>"
# Escalation recipient: used at 28 days overdue, and as the fallback when a box
# has no assigned first-aider email.
ADMIN_NOTIFICATION_EMAIL=

# --- Cron protection [SERVER ONLY] --------------------------------------------
# Random string. Vercel Cron sends "Authorization: Bearer <CRON_SECRET>" when
# this variable is set; /api/check-reminders rejects requests without it.
# Generate (PowerShell):  -join ((1..48) | ForEach-Object { '{0:x}' -f (Get-Random -Max 16) })
# Generate (bash):        openssl rand -hex 32
CRON_SECRET=

# --- Public usage page [SERVER ONLY] ------------------------------------------
# When "true", /api/usage accepts submissions WITHOUT login (factory staff
# recording what they took from a box). Submissions still pass server-side
# validation + rate limiting, and nobody can ever READ logs without login.
# Set to "false" to require login for usage submissions as well.
PUBLIC_USAGE_SUBMISSION_ENABLED=true

# [SERVER ONLY] Salt for hashing submitter IPs on the public usage form
# (sha256(ip + salt) is stored for rate limiting; raw IPs are never stored).
# Generate the same way as CRON_SECRET. Rotating it resets rate-limit history.
IP_HASH_SALT=

# [SERVER ONLY] Optional rate-limit tuning for /api/usage (defaults shown).
USAGE_RATE_LIMIT_PER_IP_PER_HOUR=10
USAGE_RATE_LIMIT_GLOBAL_PER_HOUR=120

# --- App ----------------------------------------------------------------------
# Canonical URL used in reminder emails and QR codes. No trailing slash.
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
